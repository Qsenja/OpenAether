{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAether",
  "version": "1.0.0",
  "identifier": "com.openaether.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenAether",
        "width": 1100,
        "height": 800,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'",
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "shell": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
