post_install() {
    echo ">>> Creating Python virtual environment in /opt/openaether/venv..."
    python -m venv --system-site-packages /opt/openaether/venv
    /opt/openaether/venv/bin/pip install --upgrade pip
    /opt/openaether/venv/bin/pip install -r /opt/openaether/backend/requirements.txt

    echo ">>> Pulling SearXNG Docker image..."
    docker pull searxng/searxng

    # Only create if not already present
    if ! docker ps -a --format '{{.Names}}' | grep -q "^searxng$"; then
        echo ">>> Setting up SearXNG container..."
        docker run -d \
            --name searxng \
            --restart always \
            -p 8888:8080 \
            searxng/searxng
        sleep 3
        # Enable JSON API
        docker exec searxng sh -c \
            "sed -i '/^  formats:/a\    - json' /etc/searxng/settings.yml"
        docker restart searxng
    else
        echo ">>> SearXNG container already exists, skipping creation."
    fi

    echo ">>> Enabling SearXNG systemd service..."
    systemctl enable openaether-searxng.service

    # Create user log dir
    mkdir -p "$HOME/.local/state/openaether/logs"

    echo ""
    echo ">>> OpenAether installed successfully!"
    echo ">>> IMPORTANT: Ensure Ollama and Docker services are enabled and running:"
    echo ">>>   systemctl enable --now ollama"
    echo ">>>   systemctl enable --now docker"
    echo ">>>"
    echo ">>> Launch with: openaether"
}

post_upgrade() {
    # On upgrade, just restart the container
    docker restart searxng 2>/dev/null || true
    echo ">>> OpenAether upgraded successfully!"
}

pre_remove() {
    echo ">>> Stopping SearXNG..."
    systemctl disable openaether-searxng.service
    docker stop searxng
    docker rm searxng
}
